{
  "name": "saravia-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:auth": "pnpm --filter auth-service start:dev",
    "dev:booking": "pnpm --filter booking-service start:dev",
    "dev:payment": "pnpm --filter payment-service start:dev",
    "dev:ai": "pnpm --filter ai-service start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ]
}
